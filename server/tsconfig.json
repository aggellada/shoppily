{
  "compilerOptions": {
    // 1. File Layout (Fixed)
    "rootDir": "./src",
    "outDir": "./dist",

    // 2. Environment Settings (Fixed for Node.js)
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    
    "lib": ["esnext"],
    "types": ["node"],

    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,

    // Recommended Options
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  
  // 3. Folder targeting (Fixed for Editor Errors)
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}